<% layout('layout') %>

<div class="d-flex justify-content-center align-items-center" style="min-height: 60vh;">
  <div class="card shadow-sm" style="max-width: 520px; width: 100%;">
    <div class="card-body p-4 p-lg-5 text-center">
      <div class="mb-4">
        <a href="/" class="text-decoration-none">
          <div class="fw-bold fs-4 text-success">Baze MSSN</div>
        </a>
      </div>

      <% if (success) { %>
        <div class="mb-4">
          <div class="text-success mb-3">
            <i class="bi bi-check-circle-fill" style="font-size: 3rem;"></i>
          </div>
          <h4 class="text-success mb-3">Email Verified Successfully!</h4>
          <p class="text-muted mb-4">
            Your email has been verified. You can now access all features of the platform.
          </p>
          <div class="d-grid gap-2">
            <a href="/accounts/login" class="btn btn-success btn-lg">
              <i class="bi bi-box-arrow-in-right me-1"></i> Sign In
            </a>
            <a href="/" class="btn btn-outline-success">
              <i class="bi bi-house me-1"></i> Go to Home
            </a>
          </div>
        </div>
      <% } else { %>
        <div class="mb-4">
          <div class="text-danger mb-3">
            <i class="bi bi-exclamation-triangle-fill" style="font-size: 3rem;"></i>
          </div>
          <h4 class="text-danger mb-3">Verification Failed</h4>
          <p class="text-muted mb-4">
            <%= error || 'The verification link is invalid or has expired. Please request a new verification email.' %>
          </p>
          <div class="d-grid gap-2">
            <a href="/accounts/login" class="btn btn-success btn-lg">
              <i class="bi bi-box-arrow-in-right me-1"></i> Sign In
            </a>
            <a href="/accounts/register" class="btn btn-outline-success">
              <i class="bi bi-person-plus me-1"></i> Register Again
            </a>
          </div>
        </div>
      <% } %>
    </div>
  </div>
</div>
