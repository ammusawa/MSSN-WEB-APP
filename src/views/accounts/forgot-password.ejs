<% layout('layout') %>

<div class="d-flex justify-content-center align-items-center" style="min-height: 60vh;">
  <div class="card shadow-sm" style="max-width: 520px; width: 100%;">
    <div class="card-body p-4 p-lg-5">
      <div class="text-center mb-4">
        <a href="/" class="text-decoration-none">
          <div class="fw-bold fs-4 text-success">Baze MSSN</div>
        </a>
        <div class="text-muted">Reset your password</div>
      </div>

      <form method="post" class="vstack gap-3">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>"/>

        <div>
          <label for="email" class="form-label">Email Address</label>
          <input id="email" type="email" name="email" class="form-control" placeholder="Enter your email address" required>
          <div class="form-text">We'll send a password reset link to this email</div>
        </div>

        <div class="d-grid mt-2">
          <button class="btn btn-success btn-lg">Send Reset Link</button>
        </div>
      </form>

      <div class="text-center mt-4">
        <p class="text-muted small mb-0">
          Remember your password? 
          <a href="/accounts/login" class="text-success text-decoration-none fw-semibold">Sign in</a>
        </p>
      </div>
    </div>
  </div>
</div>
