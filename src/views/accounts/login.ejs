<% layout('layout') %>

<div class="d-flex justify-content-center align-items-center" style="min-height: 60vh;">
  <div class="card shadow-sm" style="max-width: 520px; width: 100%;">
    <div class="card-body p-4 p-lg-5">
      <div class="text-center mb-4">
        <a href="/" class="text-decoration-none">
          <div class="fw-bold fs-4 text-success">Baze MSSN</div>
        </a>
        <div class="text-muted">Sign in to continue</div>
      </div>

      <form method="post" class="vstack gap-3">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>"/>
        <% if (redirect) { %>
          <input type="hidden" name="redirect" value="<%= redirect %>"/>
        <% } %>

        <div>
          <label for="username" class="form-label">Username</label>
          <input id="username" name="username" class="form-control form-control-lg" placeholder="Enter your username" required autofocus>
        </div>

        <div>
          <label for="password" class="form-label d-flex justify-content-between">
            <span>Password</span>
            <a href="/accounts/forgot-password" class="small text-success">Forgot password?</a>
          </label>
          <input id="password" type="password" name="password" class="form-control form-control-lg" placeholder="Enter your password" required>
        </div>

        <div class="d-grid mt-2">
          <button class="btn btn-success btn-lg">Sign In</button>
        </div>
      </form>

      <div class="text-center mt-4 small text-muted">
        Don't have an account? 
        <a href="/accounts/register" class="text-success text-decoration-none fw-semibold">Create one</a>
      </div>
    </div>
  </div>
</div>
