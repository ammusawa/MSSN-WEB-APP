<% layout('layout') %>

<div class="d-flex justify-content-center align-items-center" style="min-height: 60vh;">
  <div class="card shadow-sm" style="max-width: 520px; width: 100%;">
    <div class="card-body p-4 p-lg-5">
      <div class="text-center mb-4">
        <a href="/" class="text-decoration-none">
          <div class="fw-bold fs-4 text-success">Baze MSSN</div>
        </a>
        <div class="text-muted">Set new password</div>
      </div>

      <form method="post" class="vstack gap-3">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>"/>
        <input type="hidden" name="token" value="<%= token %>"/>

        <div>
          <label for="password" class="form-label">New Password</label>
          <input id="password" type="password" name="password" class="form-control" placeholder="Enter new password" minlength="6" required>
          <div class="form-text">Minimum 6 characters</div>
        </div>

        <div>
          <label for="confirmPassword" class="form-label">Confirm New Password</label>
          <input id="confirmPassword" type="password" name="confirmPassword" class="form-control" placeholder="Confirm new password" required>
        </div>

        <div class="d-grid mt-2">
          <button class="btn btn-success btn-lg">Update Password</button>
        </div>
      </form>

      <div class="text-center mt-4">
        <p class="text-muted small mb-0">
          Remember your password? 
          <a href="/accounts/login" class="text-success text-decoration-none fw-semibold">Sign in</a>
        </p>
      </div>
    </div>
  </div>
</div>

<script>
  // Password confirmation validation
  document.addEventListener('DOMContentLoaded', function() {
    const password = document.getElementById('password');
    const confirmPassword = document.getElementById('confirmPassword');
    
    function validatePassword() {
      if (password.value !== confirmPassword.value) {
        confirmPassword.setCustomValidity('Passwords do not match');
      } else {
        confirmPassword.setCustomValidity('');
      }
    }
    
    password.addEventListener('change', validatePassword);
    confirmPassword.addEventListener('keyup', validatePassword);
  });
</script>
