<% layout('layout') %>
<div class="d-flex justify-content-between align-items-center mb-3">
  <h3 class="mb-0">Donations</h3>
  <div class="d-flex gap-2">
    <a class="btn btn-sm btn-outline-success" href="/admin/dashboard">Dashboard</a>
    <a class="btn btn-sm btn-outline-danger" href="/admin/donations/export.pdf">
      <i class="bi bi-file-pdf me-1"></i>Export PDF
    </a>
    <a class="btn btn-sm btn-outline-success" href="/admin/donations/export.csv">
      <i class="bi bi-file-earmark-spreadsheet me-1"></i>Export CSV
    </a>
  </div>
</div>
<div class="table-responsive">
  <table class="table table-sm table-striped">
    <thead><tr><th>Name</th><th>Email</th><th>Amount</th><th>Status</th><th>Reference</th><th>Date</th></tr></thead>
    <tbody>
      <% donations.forEach(d => { %>
        <tr>
          <td><%= d.fullName %></td>
          <td><%= d.email %></td>
          <td>₦<%= d.amount %></td>
          <td><span class="badge <%= d.status==='SUCCESS'?'text-bg-success':(d.status==='FAILED'?'text-bg-danger':'text-bg-secondary') %>"><%= d.status %></span></td>
          <td><%= d.reference %></td>
          <td><%= new Date(d.createdAt).toLocaleString() %></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>
