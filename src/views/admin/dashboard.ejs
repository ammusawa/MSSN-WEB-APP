<% layout('layout') %>

<div class="d-flex align-items-center justify-content-between mb-4">
  <h3 class="mb-0">Admin Dashboard</h3>
  <div class="d-flex gap-2">
    <a class="btn btn-sm btn-outline-success" href="/">Home</a>
  </div>
</div>

<!-- KPI Cards -->
<div class="row g-3 mb-4">
  <div class="col-md-3">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body d-flex align-items-center gap-3">
        <span class="bg-success bg-opacity-10 text-primary rounded-circle d-inline-flex align-items-center justify-content-center" style="width:48px;height:48px;">
          <i class="bi bi-people fs-5"></i>
        </span>
        <div>
          <div class="text-muted small">Users</div>
          <div class="fs-4 fw-semibold"><%= Number(totals.users).toLocaleString() %></div>
        </div>
      </div>
      <div class="card-footer bg-white border-0 pt-0">
        <a href="/admin/users" class="small text-decoration-none text-success"><i class="bi bi-arrow-right-short"></i> Manage users</a>
      </div>
    </div>
  </div>

  <div class="col-md-3">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body d-flex align-items-center gap-3">
        <span class="bg-success bg-opacity-10 text-success rounded-circle d-inline-flex align-items-center justify-content-center" style="width:48px;height:48px;">
          <i class="bi bi-folder2-open fs-5"></i>
        </span>
        <div>
          <div class="text-muted small">Resources</div>
          <div class="fs-4 fw-semibold"><%= Number(totals.resources).toLocaleString() %></div>
        </div>
      </div>
      <div class="card-footer bg-white border-0 pt-0">
        <a href="/admin/resources" class="small text-decoration-none text-success"><i class="bi bi-arrow-right-short"></i> Manage resources</a>
      </div>
    </div>
  </div>

  <div class="col-md-3">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body d-flex align-items-center gap-3">
        <span class="bg-info bg-opacity-10 text-info rounded-circle d-inline-flex align-items-center justify-content-center" style="width:48px;height:48px;">
          <i class="bi bi-megaphone fs-5"></i>
        </span>
        <div>
          <div class="text-muted small">Announcements</div>
          <div class="fs-4 fw-semibold"><%= Number(totals.announcements).toLocaleString() %></div>
        </div>
      </div>
      <div class="card-footer bg-white border-0 pt-0">
        <a href="/admin/announcements" class="small text-decoration-none text-success"><i class="bi bi-arrow-right-short"></i> Manage announcements</a>
      </div>
    </div>
  </div>

  <div class="col-md-3">
    <div class="card border-0 shadow-sm h-100">
      <div class="card-body d-flex align-items-center gap-3">
        <span class="bg-warning bg-opacity-10 text-warning rounded-circle d-inline-flex align-items-center justify-content-center" style="width:48px;height:48px;">
          <i class="bi bi-cash-coin fs-5"></i>
        </span>
        <div>
          <div class="text-muted small">Donations (success)</div>
          <div class="fs-4 fw-semibold"><%= Number(totals.donations).toLocaleString() %></div>
        </div>
      </div>
      <div class="card-footer bg-white border-0 pt-0 d-flex justify-content-between">
        <a href="/admin/donations" class="small text-decoration-none text-success"><i class="bi bi-arrow-right-short"></i> View all</a>
        <div class="d-flex gap-2">
          <a href="/admin/donations/export.pdf" class="small text-decoration-none text-danger"><i class="bi bi-file-pdf"></i> PDF</a>
          <a href="/admin/donations/export.csv" class="small text-decoration-none text-success"><i class="bi bi-file-earmark-spreadsheet"></i> CSV</a>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Analytics Overview -->
<div class="row g-4 mb-4">
  <div class="col-lg-8">
    <div class="card border-0 shadow-sm">
      <div class="card-header bg-white border-0 pb-0">
        <h5 class="mb-0">Activity Overview (Last 7 Days)</h5>
      </div>
      <div class="card-body">
        <div class="row g-3">
          <div class="col-md-3">
            <div class="text-center">
              <div class="text-success mb-1">
                <i class="bi bi-box-arrow-in-right" style="font-size: 1.5rem;"></i>
              </div>
              <h6 class="mb-1"><%= analytics.recent.logins %></h6>
              <div class="text-muted small">Logins</div>
            </div>
          </div>
          <div class="col-md-3">
            <div class="text-center">
              <div class="text-primary mb-1">
                <i class="bi bi-cloud-arrow-down" style="font-size: 1.5rem;"></i>
              </div>
              <h6 class="mb-1"><%= analytics.recent.downloads %></h6>
              <div class="text-muted small">Downloads</div>
            </div>
          </div>
          <div class="col-md-3">
            <div class="text-center">
              <div class="text-info mb-1">
                <i class="bi bi-eye" style="font-size: 1.5rem;"></i>
              </div>
              <h6 class="mb-1"><%= analytics.recent.views %></h6>
              <div class="text-muted small">Views</div>
            </div>
          </div>
          <div class="col-md-3">
            <div class="text-center">
              <div class="text-warning mb-1">
                <i class="bi bi-person-plus" style="font-size: 1.5rem;"></i>
              </div>
              <h6 class="mb-1"><%= analytics.recent.registrations %></h6>
              <div class="text-muted small">New Users</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
  
  <div class="col-lg-4">
    <div class="card border-0 shadow-sm">
      <div class="card-header bg-white border-0 pb-0">
        <h5 class="mb-0">Top Resources</h5>
      </div>
      <div class="card-body">
        <% if (analytics.topResources.length > 0) { %>
          <% analytics.topResources.forEach((item, index) => { %>
            <div class="d-flex align-items-center mb-2">
              <div class="text-muted me-2">#<%= index + 1 %></div>
              <div class="flex-grow-1">
                <div class="small fw-semibold"><%= item.Resource.title %></div>
                <div class="text-muted small"><%= item.Resource.fileType %></div>
              </div>
              <div class="text-success small">
                <i class="bi bi-download me-1"></i><%= item.downloadCount %>
              </div>
            </div>
          <% }) %>
        <% } else { %>
          <div class="text-muted text-center py-3">
            <i class="bi bi-graph-down"></i><br>
            No download data yet
          </div>
        <% } %>
      </div>
    </div>
  </div>
</div>

<!-- Latest Donations -->
<div class="card border-0 shadow-sm">
  <div class="card-body">
    <div class="d-flex align-items-center justify-content-between mb-2">
      <h5 class="mb-0">Latest Donations</h5>
      <a href="/admin/donations" class="small text-decoration-none text-success"><i class="bi bi-list"></i> All donations</a>
    </div>

    <div class="table-responsive">
      <table class="table table-striped table-hover align-middle mb-0">
        <thead class="table-light small text-muted text-uppercase">
          <tr>
            <th>Name</th>
            <th>Email</th>
            <th>Amount</th>
            <th>Reference</th>
            <th>Date</th>
          </tr>
        </thead>
        <tbody>
          <% if (!latestDonations.length) { %>
            <tr>
              <td colspan="5" class="text-center text-muted py-4">
                <i class="bi bi-emoji-neutral me-1"></i> No recent donations.
              </td>
            </tr>
          <% } %>

          <% latestDonations.forEach(d => { %>
            <tr>
              <td><%= d.fullName %></td>
              <td class="text-muted small"><%= d.email %></td>
              <td>₦<%= Number(d.amount).toLocaleString() %></td>
              <td class="small"><code><%= d.reference %></code></td>
              <td class="small"><%= new Date(d.createdAt).toLocaleString() %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<!-- RBAC Quick Links -->
<div class="row g-3 mt-4">
  <div class="col-md-4">
    <a class="btn btn-outline-success w-100" href="/admin/rbac/roles">
      <i class="bi bi-shield-lock me-1"></i> Manage Roles & Permissions
    </a>
  </div>
  <div class="col-md-4">
    <a class="btn btn-outline-success w-100" href="/admin/rbac/users">
      <i class="bi bi-person-badge me-1"></i> Assign Roles to Users
    </a>
  </div>
  <div class="col-md-4">
    <a class="btn btn-outline-success w-100" href="/admin/users/new">
      <i class="bi bi-person-plus me-1"></i> Onboard New User
    </a>
  </div>
</div>